            "params": [
              {
                "name": "ticker",
                "value": "",
                "type": "query"
              },
              {
                "name": "ex_dividend_date",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List Stock Dividends"
        }
      ]
    },
    {
      "info": {
        "name": "News",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Ticker News",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.polygon.io/v2/reference/news",
            "params": [
              {
                "name": "ticker",
                "value": "",
                "type": "query"
              },
              {
                "name": "published_utc",
                "value": "",
                "type": "query"
              },
              {
                "name": "order",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List Ticker News"
